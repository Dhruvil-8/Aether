AETHER_LISTEN_ADDR=0.0.0.0:9000
AETHER_ADVERTISE_ADDR=
AETHER_DATA_DIR=/var/lib/aether

# Tor mode
AETHER_REQUIRE_TOR=true
AETHER_DEV_CLEARNET=false
AETHER_MANAGE_TOR=false
AETHER_TOR_BINARY=tor
AETHER_TOR_SOCKS=127.0.0.1:9050
AETHER_TOR_CONTROL=127.0.0.1:9051
AETHER_TOR_DIAL_TIMEOUT_SEC=5
AETHER_TOR_STARTUP_TIMEOUT_SEC=30
AETHER_TOR_HEALTH_INTERVAL_SEC=30

# Network
AETHER_BOOTSTRAP_PEERS=
AETHER_TARGET_PEERS=8
AETHER_BOOTSTRAP_INTERVAL_SEC=300
AETHER_PEER_EXCHANGE_INTERVAL_SEC=120
AETHER_SYNC_INTERVAL_SEC=180

# Sync and resource controls
AETHER_SYNC_BATCH_SIZE=256
AETHER_SYNC_WINDOW_SIZE=32
AETHER_MAX_SYNC_RESPONSE_MSGS=256
AETHER_MAX_SYNC_META_OFFSETS=128
AETHER_MAX_OPEN_CONNECTIONS=32
AETHER_MAX_MSG_PER_SEC=20
AETHER_MAX_CONTROL_PER_SEC=30
AETHER_MAX_JSON_PAYLOAD_BYTES=1048576
AETHER_CONN_IDLE_TIMEOUT_SEC=90

# Peer policy
AETHER_PEER_BACKOFF_SEC=30
AETHER_PEER_SCORE_DECAY_SEC=3600
AETHER_PEER_BAN_THRESHOLD=8
AETHER_PEER_BAN_DURATION_SEC=900
AETHER_PEER_EVICTION_SCORE=16
AETHER_PEER_EVICTION_COOLDOWN_SEC=1800

# Archive behavior
AETHER_ARCHIVE_MODE=false
AETHER_RELAY_HISTORY_WINDOW=4096

# Logging
AETHER_LOG_LEVEL=info
